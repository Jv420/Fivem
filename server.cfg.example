# =========================================================
# Jv420 FiveM Server Config - Full Starter Serverpack
# Kopieer dit bestand naar server.cfg en vul je eigen gegevens in.
# =========================================================

# Server basis
endpoint_add_tcp "0.0.0.0:30120"
endpoint_add_udp "0.0.0.0:30120"
sv_maxclients 48
set steam_webApiKey "none"
sets tags "roleplay, qbcore, economy, dutch, nl, starter, cars, jobs"
sets locale "nl-NL"
sv_hostname "Jv420 Roleplay | Nederlandse Economy RP"
sets sv_projectName "Jv420 FiveM"
sets sv_projectDesc "Nederlandse QBCore economy roleplay server met starter jobs, HUD, bank en voertuigen"

# OneSync
set onesync on

# Database
set mysql_connection_string "mysql://root:password@localhost/fivem_qbcore?charset=utf8mb4"

# License key
sv_licenseKey "JOUW_FIVEM_LICENSE_KEY_HIER"

# Security / privacy
sv_scriptHookAllowed 0
set sv_enforceGameBuild 3258

# Voice
setr voice_useNativeAudio true
setr voice_useSendingRangeOnly true
setr voice_defaultCycle "F11"
setr voice_defaultRadioVolume 60
setr voice_defaultPhoneVolume 70

# QBCore language
setr qb_locale "nl"

# =========================================================
# Resource start volgorde
# =========================================================

# FiveM default
ensure mapmanager
ensure chat
ensure spawnmanager
ensure sessionmanager
ensure basic-gamemode
ensure hardcap

# Database / libraries
ensure oxmysql
ensure ox_lib

# QBCore core
ensure qb-core

# Overextended / inventory / target
ensure ox_target
ensure ox_inventory

# QBCore standaard resources
ensure qb-multicharacter
ensure qb-spawn
ensure qb-apartments
ensure qb-clothing
ensure qb-weathersync
ensure qb-smallresources
ensure qb-hud
ensure qb-management
ensure qb-banking
ensure qb-shops
ensure qb-phone
ensure qb-garages
ensure qb-vehiclesales
ensure qb-vehiclekeys
ensure qb-policejob
ensure qb-ambulancejob

# Eigen Jv420 resources
ensure jv-loading
ensure jv-discordlogs
ensure jv-notify
ensure jv-adminhelp
ensure jv-hud
ensure jv-bank
ensure jv-starterjobs
ensure jv-weaponshop
ensure jv-garage
ensure jv-vehicles
ensure jv-dealership
ensure jv-carspawner
ensure jv-service
ensure jv-rpcommands

# =========================================================
# Admin permissions
# Vervang license:xxxxx door jouw eigen identifier.
# Gebruik in server console: status
# =========================================================

add_ace group.admin command allow
add_ace group.admin command.quit deny
add_principal identifier.license:VUL_JE_LICENSE_IDENTIFIER_HIER group.admin

# QBCore permissies
add_ace resource.qb-core command allow
